# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DEV_DISCORD_TOKEN=your_dev_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
OWNER_ID=your_discord_user_id

# Database Configuration (MongoDB Atlas)
# Format: mongodb+srv://USERNAME:PASSWORD@CLUSTER_HOST/DATABASE_NAME?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/bytebot-dev?retryWrites=true&w=majority



# Session Configuration
SESSION_SECRET=your_random_session_secret_here

# Dashboard Configuration
DISCORD_CALLBACK_URL=http://localhost:3000/auth/callback
DASHBOARD_URL=http://localhost:3000

# Server Configuration
PORT=3000
NODE_ENV=development
DEFAULT_TIMEZONE=Asia/Jakarta

# Genius Lyrics API (optional)
GENIUS_CLIENT_ID=your_genius_client_id
GENIUS_API_TOKEN=your_genius_api_token

# Minecraft server (non-secret but environment-based for dev/prod split)
MC_SERVER_IP=play.example.com
MC_SERVER_NAME=My Server
MC_SERVER_PORT=25565

# Pterodactyl (sensitive)
PTERODACTYL_API_KEY=ptlc_xxx
PTERODACTYL_URL=https://panel.example.com
SERVER_ID=uuid-of-server
SERVERCONTROL_CHANNELID=123456789012345678

# Slash commands deployment toggle
DEPLOY_COMMANDS=true

# Social Alert API Keys (Optional - for future implementation)
# YouTube Data API v3
# Get key from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Twitch API
# Get credentials from: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here

# Twitter/X API v2
# Get token from: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Instagram (Meta) API - Optional for Instagram alerts
# Graph API recommended for Business/Creator accounts
IG_APP_ID=your_facebook_app_id_here
IG_APP_SECRET=your_facebook_app_secret_here
IG_ACCESS_TOKEN=your_long_lived_ig_access_token_here

# Heroku Specific (Set automatically by Heroku, leave empty for local)
# HEROKU_APP_NAME=your-app-name
