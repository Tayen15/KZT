<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= guild.name %> - Social Alerts</title>
    <link rel="stylesheet" href="/css/output.css">
</head>
<body class="bg-[#1a1d23] text-white">
    <div class="flex h-screen overflow-hidden">
        <!-- Dashboard Sidebar -->
        <% const currentPage='social-alert' ; %>
        <%- include('../partials/dashboard-sidebar', { guild, currentPage, user, guilds, featureStates }) %>

        <!-- Main Content -->
        <main class="flex-1 overflow-y-auto ml-0 lg:ml-64 transition-all duration-300">
            <!-- Sticky Top Bar -->
            <div class="sticky top-0 z-10 bg-[#23272f]/95 backdrop-blur-sm border-b border-[#3a3f4b] px-8 py-4">
                <div class="flex items-center justify-between">
                    <div>
                        <h1 class="text-2xl font-bold text-white flex items-center gap-3">
                            <svg class="w-6 h-6 text-[#5865F2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
                            </svg>
                            Social Alerts
                        </h1>
                        <p class="text-sm text-[#b9bbbe] mt-1">Get notified when your favorite creators go live or post new content</p>
                    </div>
                    <button onclick="openAddAlertModal()" class="bg-[#5865F2] hover:bg-[#4752c4] px-4 py-2 rounded-lg font-semibold transition-all flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                        </svg>
                        Add Alert
                    </button>
                </div>
            </div>

            <!-- Content Area -->
            <div class="p-8">
                <!-- Platform Tabs -->
                <div class="flex gap-2 mb-6 overflow-x-auto pb-2">
                    <button onclick="filterAlerts('all')" class="filter-tab active px-4 py-2 rounded-lg font-semibold transition-all whitespace-nowrap">
                        All Platforms
                    </button>
                    <button onclick="filterAlerts('youtube')" class="filter-tab px-4 py-2 rounded-lg font-semibold transition-all whitespace-nowrap flex items-center gap-2">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                        </svg>
                        YouTube
                    </button>
                    <button onclick="filterAlerts('twitch')" class="filter-tab px-4 py-2 rounded-lg font-semibold transition-all whitespace-nowrap flex items-center gap-2">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714Z"/>
                        </svg>
                        Twitch
                    </button>
                    <button onclick="filterAlerts('twitter')" class="filter-tab px-4 py-2 rounded-lg font-semibold transition-all whitespace-nowrap flex items-center gap-2">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                        </svg>
                        Twitter/X
                    </button>
                    <button onclick="filterAlerts('instagram')" class="filter-tab px-4 py-2 rounded-lg font-semibold transition-all whitespace-nowrap flex items-center gap-2">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M7 2h10a5 5 0 015 5v10a5 5 0 01-5 5H7a5 5 0 01-5-5V7a5 5 0 015-5zm0 2a3 3 0 00-3 3v10a3 3 0 003 3h10a3 3 0 003-3V7a3 3 0 00-3-3H7zm5 3.5a5.5 5.5 0 110 11 5.5 5.5 0 010-11zm0 2a3.5 3.5 0 100 7 3.5 3.5 0 000-7zm6.25-.75a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5z"/>
                        </svg>
                        Instagram
                    </button>
                </div>

                <!-- Alerts Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="alertsGrid">
                    <% if (alerts && alerts.length > 0) { %>
                        <% alerts.forEach(alert => { %>
                            <div class="alert-card bg-[#2b2f38] border border-[#3a3f4b] rounded-xl p-5 hover:border-[#5865F2] transition-all" data-platform="<%= alert.platform %>">
                                <!-- Alert Header -->
                                <div class="flex items-start justify-between mb-4">
                                    <div class="flex items-center gap-3">
                                        <!-- Platform Icon -->
                                        <div class="p-2 bg-<%= alert.platform === 'youtube' ? '[#FF0000]' : (alert.platform === 'twitch' ? '[#9146FF]' : (alert.platform === 'instagram' ? '[#E1306C]' : '[#1DA1F2]')) %>/10 rounded-lg">
                                            <% if (alert.platform === 'youtube') { %>
                                                <svg class="w-5 h-5 text-[#FF0000]" fill="currentColor" viewBox="0 0 24 24">
                                                    <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                                                </svg>
                                            <% } else if (alert.platform === 'twitch') { %>
                                                <svg class="w-5 h-5 text-[#9146FF]" fill="currentColor" viewBox="0 0 24 24">
                                                    <path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714Z"/>
                                                </svg>
                                            <% } else if (alert.platform === 'instagram') { %>
                                                <svg class="w-5 h-5 text-[#E1306C]" fill="currentColor" viewBox="0 0 24 24">
                                                    <path d="M7 2h10a5 5 0 015 5v10a5 5 0 01-5 5H7a5 5 0 01-5-5V7a5 5 0 015-5zm0 2a3 3 0 00-3 3v10a3 3 0 003 3h10a3 3 0 003-3V7a3 3 0 00-3-3H7zm5 3.5a5.5 5.5 0 110 11 5.5 5.5 0 010-11zm0 2a3.5 3.5 0 100 7 3.5 3.5 0 000-7zm6.25-.75a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5z"/>
                                                </svg>
                                            <% } else { %>
                                                <svg class="w-5 h-5 text-[#1DA1F2]" fill="currentColor" viewBox="0 0 24 24">
                                                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                                                </svg>
                                            <% } %>
                                        </div>
                                        <div>
                                            <h3 class="font-bold text-white"><%= alert.username || 'Unnamed' %></h3>
                                            <p class="text-xs text-[#b9bbbe] capitalize"><%= alert.platform %></p>
                                        </div>
                                    </div>
                                    <!-- Status Badge -->
                                    <%- include('../components/status-badge', { enabled: alert.enabled, enabledText: 'Active', disabledText: 'Inactive' }) %>
                                </div>

                                <!-- Notification Types -->
                                <div class="flex flex-wrap gap-2 mb-4">
                                    <% if (alert.notifyLive) { %>
                                        <span class="text-xs bg-[#ED4245]/10 text-[#ED4245] border border-[#ED4245]/30 px-2 py-1 rounded">🔴 Live</span>
                                    <% } %>
                                    <% if (alert.notifyVideo) { %>
                                        <span class="text-xs bg-[#5865F2]/10 text-[#5865F2] border border-[#5865F2]/30 px-2 py-1 rounded">🎥 Videos</span>
                                    <% } %>
                                    <% if (alert.notifyPost) { %>
                                        <span class="text-xs bg-[#57F287]/10 text-[#57F287] border border-[#57F287]/30 px-2 py-1 rounded">📝 Posts</span>
                                    <% } %>
                                </div>

                                <!-- Stats -->
                                <div class="flex items-center justify-between text-xs text-[#b9bbbe] mb-4">
                                    <span><%= alert.totalAlerts %> alerts sent</span>
                                    <% const __speed = (alert.checkInterval && alert.checkInterval <= 7) ? 'Fast' : 'Slow'; %>
                                    <span>Speed: <%= __speed %></span>
                                </div>

                                <!-- Actions -->
                                <div class="flex gap-2">
                                    <button onclick="editAlert('<%= alert.id %>')" class="flex-1 bg-[#5865F2] hover:bg-[#4752c4] px-3 py-2 rounded-lg text-sm font-semibold transition-all">
                                        Edit
                                    </button>
                                    <button onclick="toggleAlert('<%= alert.id %>', '<%= !alert.enabled %>')" class="px-3 py-2 bg-[#3a3f4b] hover:bg-[#32363f] rounded-lg text-sm font-semibold transition-all">
                                        <%= alert.enabled ? 'Disable' : 'Enable' %>
                                    </button>
                                    <button onclick="deleteAlert('<%= alert.id %>')" class="px-3 py-2 bg-[#ED4245]/10 hover:bg-[#ED4245]/20 text-[#ED4245] rounded-lg text-sm font-semibold transition-all">
                                        Delete
                                    </button>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <!-- Empty State -->
                        <div class="col-span-full bg-[#2b2f38] border border-[#3a3f4b] rounded-xl p-12 text-center">
                            <svg class="w-16 h-16 mx-auto text-[#b9bbbe] mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
                            </svg>
                            <h3 class="text-xl font-bold text-white mb-2">No Social Alerts Yet</h3>
                            <p class="text-[#b9bbbe] mb-4">Start monitoring your favorite creators by adding your first alert</p>
                            <button onclick="openAddAlertModal()" class="bg-[#5865F2] hover:bg-[#4752c4] px-6 py-3 rounded-lg font-semibold transition-all inline-flex items-center gap-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                                </svg>
                                Add Your First Alert
                            </button>
                        </div>
                    <% } %>
                </div>
            </div>
        </main>
    </div>

    <!-- Add/Edit Alert Modal -->
    <div id="alertModal" class="fixed inset-0 bg-black/50 items-center justify-center z-50 p-4" style="display: none;">
        <div class="bg-[#2b2f38] rounded-xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
            <!-- Modal Header -->
            <div class="sticky top-0 bg-[#2b2f38] border-b border-[#3a3f4b] p-6 flex items-center justify-between">
                <h2 class="text-xl font-bold" id="modalTitle">Add Social Alert</h2>
                <button onclick="closeAlertModal()" class="text-[#b9bbbe] hover:text-white transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>

            <!-- Modal Body -->
            <form id="alertForm" class="p-6 space-y-4">
                <input type="hidden" id="alertId" name="alertId">

                <!-- Platform Selection -->
                <div>
                    <label class="block text-sm font-semibold mb-2">Platform</label>
                    <select name="platform" id="platformSelect" required class="w-full bg-[#23272f] border border-[#3a3f4b] rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-[#5865F2] focus:ring-2 focus:ring-[#5865F2]/20 transition-all">
                        <option value="">Select platform...</option>
                        <option value="youtube">YouTube</option>
                        <option value="twitch">Twitch</option>
                        <option value="twitter">Twitter/X</option>
                        <option value="instagram">Instagram</option>
                    </select>
                </div>

                <!-- Username -->
                <div>
                    <label class="block text-sm font-semibold mb-2">Username/Channel Name</label>
                    <input type="text" name="username" id="usernameInput" required class="w-full bg-[#23272f] border border-[#3a3f4b] rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-[#5865F2] focus:ring-2 focus:ring-[#5865F2]/20 transition-all" placeholder="Enter username or channel name">
                </div>

                <!-- Channel URL (Optional) -->
                <div>
                    <label class="block text-sm font-semibold mb-2">Channel/Profile URL <span class="text-[#b9bbbe] font-normal">(Optional)</span></label>
                    <input type="url" name="channelUrl" id="channelUrlInput" class="w-full bg-[#23272f] border border-[#3a3f4b] rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-[#5865F2] focus:ring-2 focus:ring-[#5865F2]/20 transition-all" placeholder="https://youtube.com/@username">
                </div>

                <!-- Discord Channel -->
                <div>
                    <label class="block text-sm font-semibold mb-2">Notification Channel</label>
                    <%- include('../components/channel-dropdown', { channels, selectedChannelId: '', fieldName: 'channelId' }) %>
                </div>

                <!-- Notification Types -->
                <div>
                    <label class="block text-sm font-semibold mb-3">Notification Types</label>
                    <div class="space-y-2">
                        <label class="flex items-center gap-3 cursor-pointer">
                            <input type="checkbox" name="notifyLive" value="true" checked class="w-5 h-5 rounded border-[#3a3f4b] bg-[#23272f] text-[#5865F2] focus:ring-[#5865F2] focus:ring-offset-0">
                            <span>🔴 Notify when going live</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer">
                            <input type="checkbox" name="notifyVideo" value="true" checked class="w-5 h-5 rounded border-[#3a3f4b] bg-[#23272f] text-[#5865F2] focus:ring-[#5865F2] focus:ring-offset-0">
                            <span>🎥 Notify for new videos</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer">
                            <input type="checkbox" name="notifyPost" value="true" checked class="w-5 h-5 rounded border-[#3a3f4b] bg-[#23272f] text-[#5865F2] focus:ring-[#5865F2] focus:ring-offset-0">
                            <span>📝 Notify for new posts</span>
                        </label>
                    </div>
                </div>

                <!-- Custom Role Mention (Optional) -->
                <div>
                    <label class="block text-sm font-semibold mb-2">Mention Role <span class="text-[#b9bbbe] font-normal">(Optional)</span></label>
                    <select name="customRole" id="customRoleSelect" class="w-full bg-[#23272f] border border-[#3a3f4b] rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-[#5865F2] focus:ring-2 focus:ring-[#5865F2]/20 transition-all">
                        <option value="">No mention</option>
                        <option value="@everyone">@everyone</option>
                        <% if (roles && roles.length > 0) { %>
                            <% roles.forEach(role => { %>
                                <option value="<%= role.id %>">@<%= role.name %></option>
                            <% }); %>
                        <% } %>
                    </select>
                </div>

                <!-- Embed Color -->
                <div>
                    <label class="block text-sm font-semibold mb-2">Embed Color</label>
                    <input type="color" name="embedColor" id="embedColorInput" value="#5865F2" class="w-20 h-10 rounded-lg border border-[#3a3f4b] bg-[#23272f] cursor-pointer">
                </div>

                <!-- Check Frequency (API-friendly) -->
                <div>
                    <label class="block text-sm font-semibold mb-2">Check Frequency</label>
                    <select name="checkIntervalSpeed" id="checkIntervalSpeed" class="w-full bg-[#23272f] border border-[#3a3f4b] rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-[#5865F2] focus:ring-2 focus:ring-[#5865F2]/20 transition-all">
                        <option value="slow" selected>Slow (recommended)</option>
                        <option value="fast">Fast</option>
                    </select>
                    <!-- Hidden mapped minutes value used by API -->
                    <input type="hidden" name="checkInterval" id="checkIntervalHidden" value="15" />
                </div>

                <!-- Submit Buttons -->
                <div class="flex gap-3 pt-4">
                    <button type="button" onclick="closeAlertModal()" class="flex-1 bg-[#3a3f4b] hover:bg-[#32363f] px-6 py-3 rounded-lg font-semibold transition-all">
                        Cancel
                    </button>
                    <button type="submit" class="flex-1 bg-[#5865F2] hover:bg-[#4752c4] px-6 py-3 rounded-lg font-semibold transition-all">
                        Save Alert
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const guildId = '<%= guild.guildId %>';
        let currentFilter = 'all';

        // Filter alerts by platform
        function filterAlerts(platform) {
            currentFilter = platform;
            const tabs = document.querySelectorAll('.filter-tab');
            const cards = document.querySelectorAll('.alert-card');

            tabs.forEach(tab => {
                if (tab.textContent.toLowerCase().includes(platform) || (platform === 'all' && tab.textContent.includes('All'))) {
                    tab.classList.add('active', 'bg-[#5865F2]', 'text-white');
                    tab.classList.remove('bg-[#2b2f38]', 'text-[#b9bbbe]');
                } else {
                    tab.classList.remove('active', 'bg-[#5865F2]', 'text-white');
                    tab.classList.add('bg-[#2b2f38]', 'text-[#b9bbbe]');
                }
            });

            cards.forEach(card => {
                const cardPlatform = card.dataset.platform;
                if (platform === 'all' || cardPlatform === platform) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        // Open add alert modal
        function openAddAlertModal() {
            document.getElementById('modalTitle').textContent = 'Add Social Alert';
            document.getElementById('alertForm').reset();
            document.getElementById('alertId').value = '';
            document.getElementById('alertModal').style.display = 'flex';

            // Default frequency: slow
            const speedSelect = document.getElementById('checkIntervalSpeed');
            const hiddenInterval = document.getElementById('checkIntervalHidden');
            if (speedSelect && hiddenInterval) {
                speedSelect.value = 'slow';
                hiddenInterval.value = '15';
            }
        }

        // Close alert modal
        function closeAlertModal() {
            document.getElementById('alertModal').style.display = 'none';
        }

        // Edit alert
        async function editAlert(alertId) {
            // Fetch alert data
            const alerts = JSON.parse('<%- JSON.stringify(alerts) %>');
            const alert = alerts.find(a => a.id === alertId);
            
            if (!alert) return;

            document.getElementById('modalTitle').textContent = 'Edit Social Alert';
            document.getElementById('alertId').value = alert.id;
            document.getElementById('platformSelect').value = alert.platform;
            document.getElementById('usernameInput').value = alert.username || '';
            document.getElementById('channelUrlInput').value = alert.channelUrl || '';
            document.querySelector('select[name="channelId"]').value = alert.channelId || '';
            document.querySelector('input[name="notifyLive"]').checked = alert.notifyLive;
            document.querySelector('input[name="notifyVideo"]').checked = alert.notifyVideo;
            document.querySelector('input[name="notifyPost"]').checked = alert.notifyPost;
            document.getElementById('customRoleSelect').value = alert.customRole || '';
            document.getElementById('embedColorInput').value = alert.embedColor || '#5865F2';

            // Map interval to speed selector
            const speed = (alert.checkInterval && alert.checkInterval <= 7) ? 'fast' : 'slow';
            const speedSelect = document.getElementById('checkIntervalSpeed');
            const hiddenInterval = document.getElementById('checkIntervalHidden');
            if (speedSelect && hiddenInterval) {
                speedSelect.value = speed;
                hiddenInterval.value = speed === 'fast' ? '5' : '15';
            }

            document.getElementById('alertModal').style.display = 'flex';
        }

        // Toggle alert
        async function toggleAlert(alertId, enabled) {
            try {
                const response = await fetch(`/api/guild/${guildId}/social-alert/${alertId}/toggle`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ enabled: enabled.toString() })
                });

                const result = await response.json();
                if (result.success) {
                    location.reload();
                } else {
                    alert('Failed to toggle alert: ' + result.message);
                }
            } catch (error) {
                console.error('Error toggling alert:', error);
                alert('Failed to toggle alert');
            }
        }

        // Delete alert
        async function deleteAlert(alertId) {
            if (!confirm('Are you sure you want to delete this social alert?')) return;

            try {
                const response = await fetch(`/api/guild/${guildId}/social-alert/${alertId}`, {
                    method: 'DELETE'
                });

                const result = await response.json();
                if (result.success) {
                    location.reload();
                } else {
                    alert('Failed to delete alert: ' + result.message);
                }
            } catch (error) {
                console.error('Error deleting alert:', error);
                alert('Failed to delete alert');
            }
        }

        // Submit form
        document.getElementById('alertForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const alertId = document.getElementById('alertId').value;

            const data = {};
            for (let [key, value] of formData.entries()) {
                data[key] = value;
            }

            // Map speed to numeric minutes
            if (data.checkIntervalSpeed) {
                const mapped = data.checkIntervalSpeed === 'fast' ? 5 : 15;
                data.checkInterval = mapped.toString();
                delete data.checkIntervalSpeed;
            }

            try {
                const url = alertId 
                    ? `/api/guild/${guildId}/social-alert/${alertId}`
                    : `/api/guild/${guildId}/social-alert`;
                
                const method = alertId ? 'PUT' : 'POST';

                const response = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();
                if (result.success) {
                    location.reload();
                } else {
                    alert('Failed to save alert: ' + result.message);
                }
            } catch (error) {
                console.error('Error saving alert:', error);
                alert('Failed to save alert');
            }
        });

        // Close modal on ESC
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                closeAlertModal();
            }
        });

        // Initialize filters
        document.addEventListener('DOMContentLoaded', () => {
            filterAlerts('all');

            // Wire speed selector to hidden interval
            const speedSelect = document.getElementById('checkIntervalSpeed');
            const hiddenInterval = document.getElementById('checkIntervalHidden');
            if (speedSelect && hiddenInterval) {
                const updateHidden = () => {
                    hiddenInterval.value = speedSelect.value === 'fast' ? '5' : '15';
                };
                speedSelect.addEventListener('change', updateHidden);
                updateHidden();
            }
        });
    </script>
</body>
</html>
