<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - ByteBot Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body class="bg-[#1a1d23] text-white min-h-screen">
    <%- include('../partials/navbar') %>

    <main class="container mx-auto px-4 py-12">
        <!-- Page Header -->
        <div class="mb-8">
            <div class="flex items-center gap-3 mb-2">
                <span class="text-4xl">⚙️</span>
                <h1 class="text-4xl font-bold">Feature Toggles</h1>
            </div>
            <p class="text-[#b9bbbe]">Enable or disable dashboard features globally</p>
        </div>

        <!-- Feature Categories -->
        <% for (const [categoryKey, categoryData] of Object.entries(categories)) { %>
            <% if (featuresByCategory[categoryKey] && featuresByCategory[categoryKey].length > 0) { %>
            <div class="mb-8">
                <!-- Category Header -->
                <div class="flex items-center gap-3 mb-4">
                    <span class="text-2xl"><%= categoryData.icon %></span>
                    <h2 class="text-2xl font-bold"><%= categoryData.name %></h2>
                </div>

                <!-- Feature Cards -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    <% featuresByCategory[categoryKey].forEach(feature => { %>
                    <div class="bg-[#2b2f38] border border-[#3a3f4b] rounded-xl p-6 hover:border-[#5865F2]/50 transition-all duration-300">
                        <!-- Feature Header -->
                        <div class="flex items-start justify-between mb-4">
                            <div class="flex items-center gap-3">
                                <% if (feature.icon) { %>
                                <span class="text-3xl"><%= feature.icon %></span>
                                <% } %>
                                <div>
                                    <h3 class="text-lg font-bold"><%= feature.name %></h3>
                                    <p class="text-xs text-[#b9bbbe]"><code><%= feature.featureKey %></code></p>
                                </div>
                            </div>
                            
                            <!-- Toggle Switch -->
                            <label class="relative inline-block w-14 h-7 flex-shrink-0">
                                <input 
                                    type="checkbox" 
                                    data-feature-key="<%= feature.featureKey %>"
                                    <%= feature.enabled ? 'checked' : '' %>
                                    class="feature-toggle opacity-0 w-0 h-0"
                                >
                                <span class="absolute cursor-pointer top-0 left-0 right-0 bottom-0 bg-[#3a3f4b] rounded-full transition-all duration-300 before:absolute before:content-[''] before:h-5 before:w-5 before:left-1 before:bottom-1 before:bg-white before:rounded-full before:transition-all before:duration-300"></span>
                            </label>
                        </div>

                        <!-- Description -->
                        <p class="text-sm text-[#b9bbbe] mb-4"><%= feature.description %></p>

                        <!-- Status Badge -->
                        <div class="flex items-center gap-2">
                            <% if (feature.enabled) { %>
                            <div class="bg-green-500/10 border border-green-500/30 rounded-lg px-2 py-0.5 flex items-center gap-1.5">
                                <svg class="w-3 h-3 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                                </svg>
                                <span class="text-green-500 text-xs font-semibold">Enabled</span>
                            </div>
                            <% } else { %>
                            <div class="bg-red-500/10 border border-red-500/30 rounded-lg px-2 py-0.5 flex items-center gap-1.5">
                                <svg class="w-3 h-3 text-red-500" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                                </svg>
                                <span class="text-red-500 text-xs font-semibold">Disabled</span>
                            </div>
                            <% } %>
                            <span class="text-xs text-[#b9bbbe]">Updated <%= new Date(feature.updatedAt).toLocaleDateString() %></span>
                        </div>
                    </div>
                    <% }); %>
                </div>
            </div>
            <% } %>
        <% } %>

        <!-- Alert Box -->
        <div id="alertBox" class="fixed bottom-6 right-6 z-50 bg-[#2b2f38] text-white px-4 py-3 rounded-lg shadow-lg border border-[#3a3f4b] flex items-center gap-3 transform translate-y-32 opacity-0 pointer-events-none transition-all duration-300">
            <svg id="alertIcon" class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"></svg>
            <span id="alertText"></span>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <script>
        // Toggle switch styling
        const style = document.createElement('style');
        style.textContent = `
            .feature-toggle:checked + span {
                background-color: #5865F2;
            }
            .feature-toggle:checked + span:before {
                transform: translateX(28px);
            }
        `;
        document.head.appendChild(style);

        // Handle toggle switches
        document.querySelectorAll('.feature-toggle').forEach(toggle => {
            toggle.addEventListener('change', async function() {
                const featureKey = this.dataset.featureKey;
                const enabled = this.checked;
                const card = this.closest('.bg-\\[\\#2b2f38\\]');

                try {
                    const response = await fetch(`/api/owner/features/${featureKey}/toggle`, {
                        method: 'PATCH',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ enabled })
                    });

                    const data = await response.json();

                    if (data.success) {
                        // Update status badge
                        const statusBadge = card.querySelector('.bg-green-500\\/10, .bg-red-500\\/10');
                        if (statusBadge) {
                            if (enabled) {
                                statusBadge.className = 'bg-green-500/10 border border-green-500/30 rounded-lg px-2 py-0.5 flex items-center gap-1.5';
                                statusBadge.innerHTML = `
                                    <svg class="w-3 h-3 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                                    </svg>
                                    <span class="text-green-500 text-xs font-semibold">Enabled</span>
                                `;
                            } else {
                                statusBadge.className = 'bg-red-500/10 border border-red-500/30 rounded-lg px-2 py-0.5 flex items-center gap-1.5';
                                statusBadge.innerHTML = `
                                    <svg class="w-3 h-3 text-red-500" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                                    </svg>
                                    <span class="text-red-500 text-xs font-semibold">Disabled</span>
                                `;
                            }
                        }

                        showAlert(data.message, 'success');
                    } else {
                        // Revert toggle on error
                        this.checked = !enabled;
                        showAlert('Failed to toggle feature', 'error');
                    }
                } catch (error) {
                    console.error('Error toggling feature:', error);
                    this.checked = !enabled;
                    showAlert('Network error occurred', 'error');
                }
            });
        });

        // Alert notification
        function showAlert(message, type = 'success') {
            const alertBox = document.getElementById('alertBox');
            const alertIcon = document.getElementById('alertIcon');
            const alertText = document.getElementById('alertText');

            alertText.textContent = message;

            if (type === 'success') {
                alertBox.classList.remove('border-red-500');
                alertBox.classList.add('border-green-500');
                alertIcon.innerHTML = '<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>';
                alertIcon.classList.remove('text-red-500');
                alertIcon.classList.add('text-green-500');
            } else {
                alertBox.classList.remove('border-green-500');
                alertBox.classList.add('border-red-500');
                alertIcon.innerHTML = '<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>';
                alertIcon.classList.remove('text-green-500');
                alertIcon.classList.add('text-red-500');
            }

            // Show alert
            alertBox.classList.remove('translate-y-32', 'opacity-0', 'pointer-events-none');
            alertBox.classList.add('translate-y-0', 'opacity-100');

            // Hide after 3 seconds
            setTimeout(() => {
                alertBox.classList.add('translate-y-32', 'opacity-0', 'pointer-events-none');
                alertBox.classList.remove('translate-y-0', 'opacity-100');
            }, 3000);
        }
    </script>
</body>
</html>
