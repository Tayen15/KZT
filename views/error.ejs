<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= (typeof error !=='undefined' && error?.title) || title || 'Error' %> - ByteBot
    </title>
    <link rel="stylesheet" href="/css/output.css">
</head>

<body class="bg-[#1a1d23] text-text-primary min-h-screen flex flex-col">
    <%- include('partials/navbar') %>

        <section class="py-24 text-center bg-gradient-to-b from-dark-secondary to-dark-primary">

            <div class="container mx-auto px-4">
                <div class="max-w-2xl mx-auto text-center">
                    <!-- Error Icon -->
                    <div class="mb-8 inline-block">
                        <% const errorCode=(typeof error !=='undefined' && error?.code) || (title &&
                            title.includes('404') ? 404 : title && title.includes('500') ? 500 : 500); const
                            isWarning=errorCode===503 || errorCode===403; const borderColor=isWarning ? '#FEE75C'
                            : '#ED4245' ; const iconColor=isWarning ? '#FEE75C' : '#ED4245' ; %>
                            <div class="w-24 h-24 bg-[#2b2f38] rounded-full flex items-center justify-center mx-auto"
                                style="border: 4px solid <%= borderColor %>">
                                <% if (isWarning) { %>
                                    <!-- Warning Icon for 503/403 -->
                                    <svg class="w-12 h-12" style="color: <%= iconColor %>" fill="none"
                                        stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                                    </svg>
                                    <% } else { %>
                                        <!-- Error Icon -->
                                        <svg class="w-12 h-12" style="color: <%= iconColor %>" fill="none"
                                            stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                        </svg>
                                        <% } %>
                            </div>
                    </div>

                    <!-- Error Title -->
                    <h1 class="text-4xl text-white font-bold mb-4">
                        <%= (typeof error !=='undefined' && error?.title) || title || 'Oops! Something went wrong' %>
                    </h1>

                    <!-- Error Message -->
                    <p class="text-[#b9bbbe] text-lg mb-4 max-w-lg mx-auto">
                        <%= (typeof error !=='undefined' && error?.message) || message
                            || 'An unexpected error occurred. Please try again later.' %>
                    </p>

                    <!-- Error Description (if provided) -->
                    <% if (typeof error !=='undefined' && error?.description) { %>
                        <p class="text-[#b9bbbe] text-sm mb-8 max-w-md mx-auto opacity-80">
                            <%= error.description %>
                        </p>
                        <% } else { %>
                            <div class="mb-8"></div>
                            <% } %>

                                <!-- Feature Disabled Info Card (503 only) -->
                                <% if ((typeof error !=='undefined' && error?.code===503) || (typeof title
                                    !=='undefined' && title.includes('503'))) { %>
                                    <% const cfg=(()=> { try { return require('../config.json'); } catch { return {}; }
                                        })();
                                        const OWNER_ID = process.env.OWNER_ID || cfg.ownerId;
                                        const isOwner = user && user.discordId === OWNER_ID;
                                        %>
                                        <div
                                            class="bg-[#2b2f38] border border-[#3a3f4b] rounded-xl p-6 mb-8 max-w-md mx-auto text-left">
                                            <div class="flex items-start gap-4">
                                                <div class="p-3 bg-[#FEE75C]/10 rounded-lg flex-shrink-0">
                                                    <svg class="w-6 h-6 text-[#FEE75C]" fill="none"
                                                        stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            stroke-width="2"
                                                            d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                    </svg>
                                                </div>
                                                <div class="flex-1">
                                                    <h3 class="text-white font-semibold mb-2">Why is this happening?
                                                    </h3>
                                                    <p class="text-[#b9bbbe] text-sm leading-relaxed">
                                                        The server administrators have temporarily disabled this feature
                                                        for maintenance or configuration purposes.
                                                        <% if (isOwner) { %>
                                                            <br><br><strong class="text-[#FEE75C]">You're the bot
                                                                owner</strong> - You can enable this feature in the
                                                            Feature Toggles panel.
                                                            <% } else { %>
                                                                Please contact your server administrators for more
                                                                information.
                                                                <% } %>
                                                    </p>
                                                </div>
                                            </div>
                                        </div>
                                        <% } %>

                                            <!-- Action Buttons -->
                                            <div class="flex flex-wrap gap-4 justify-center">
                                                <% if (user && user.id) { %>
                                                    <!-- Authenticated User Buttons -->
                                                    <a href="/dashboard"
                                                        class="bg-[#5865F2] hover:bg-[#4752c4] text-white font-semibold px-8 py-3 rounded-lg transition-all duration-200 transform hover:scale-105 inline-flex items-center gap-2">
                                                        <svg class="w-5 h-5" fill="none" stroke="currentColor"
                                                            viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                                stroke-width="2"
                                                                d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                                                        </svg>
                                                        <span>Go to Dashboard</span>
                                                    </a>
                                                    <% if ((typeof error !=='undefined' && error?.code===503) || (typeof
                                                        title !=='undefined' && title.includes('503'))) { %>
                                                        <!-- Admin Link for Feature Disabled -->
                                                        <% const cfg=(()=> { try { return require('../config.json'); }
                                                            catch { return {}; } })();
                                                            const OWNER_ID = process.env.OWNER_ID || cfg.ownerId;
                                                            const isOwner = user && user.discordId === OWNER_ID;
                                                            %>
                                                            <% if (isOwner) { %>
                                                                <a href="/dashboard/owner/features"
                                                                    class="bg-[#FEE75C] hover:bg-[#FDD835] text-[#1a1d23] font-semibold px-8 py-3 rounded-lg transition-all duration-200 inline-flex items-center gap-2">
                                                                    <svg class="w-5 h-5" fill="none"
                                                                        stroke="currentColor" viewBox="0 0 24 24">
                                                                        <path stroke-linecap="round"
                                                                            stroke-linejoin="round" stroke-width="2"
                                                                            d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
                                                                    </svg>
                                                                    <span>Manage Features</span>
                                                                </a>
                                                                <% } %>
                                                                    <% } %>
                                                                        <a href="javascript:history.back()"
                                                                            class="bg-[#2b2f38] hover:bg-[#3a3f4b] border border-[#3a3f4b] hover:border-[#5865F2] text-white font-semibold px-8 py-3 rounded-lg transition-all duration-200 inline-flex items-center gap-2">
                                                                            <svg class="w-5 h-5" fill="none"
                                                                                stroke="currentColor"
                                                                                viewBox="0 0 24 24">
                                                                                <path stroke-linecap="round"
                                                                                    stroke-linejoin="round"
                                                                                    stroke-width="2"
                                                                                    d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                                                                            </svg>
                                                                            <span>Go Back</span>
                                                                        </a>
                                                                        <% } else { %>
                                                                            <!-- Guest User Buttons -->
                                                                            <a href="/"
                                                                                class="bg-[#5865F2] hover:bg-[#4752c4] text-white font-semibold px-8 py-3 rounded-lg transition-all duration-200 transform hover:scale-105 inline-flex items-center gap-2">
                                                                                <svg class="w-5 h-5" fill="none"
                                                                                    stroke="currentColor"
                                                                                    viewBox="0 0 24 24">
                                                                                    <path stroke-linecap="round"
                                                                                        stroke-linejoin="round"
                                                                                        stroke-width="2"
                                                                                        d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                                                                                </svg>
                                                                                <span>Go Home</span>
                                                                            </a>
                                                                            <a href="javascript:history.back()"
                                                                                class="bg-[#2b2f38] hover:bg-[#3a3f4b] border border-[#3a3f4b] hover:border-[#5865F2] text-white font-semibold px-8 py-3 rounded-lg transition-all duration-200 inline-flex items-center gap-2">
                                                                                <svg class="w-5 h-5" fill="none"
                                                                                    stroke="currentColor"
                                                                                    viewBox="0 0 24 24">
                                                                                    <path stroke-linecap="round"
                                                                                        stroke-linejoin="round"
                                                                                        stroke-width="2"
                                                                                        d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                                                                                </svg>
                                                                                <span>Go Back</span>
                                                                            </a>
                                                                            <% } %>
                                            </div>

                </div>
            </div>
        </section>

        <%- include('partials/footer') %>
</body>

</html>